# Copy to .env.local for local overrides.

# Optional: absolute origin of the FastAPI API (no trailing slash).
# Leave UNSET for same-origin: Vercel Services (frontend + api in one project), or `npm run dev` + Vite proxy.
# Set ONLY when the UI and API are on different hosts, e.g.:
# VITE_API_BASE_URL=https://your-api.onrender.com
