# Copy to .env.local for local overrides. On Vercel, set this in Project → Settings → Environment Variables.

# FastAPI backend origin (no trailing slash). Required for production builds served from Vercel.
# Example: https://networkpulse-api.onrender.com
# Leave empty when using `npm run dev` with Vite proxy to localhost:8000.
# VITE_API_BASE_URL=
